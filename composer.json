{
    "name": "ux2dev/borica",
    "description": "PHP library for BORICA eCommerce CGI payment gateway interface",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-openssl": "*",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ux2Dev\\Borica\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ux2Dev\\Borica\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
